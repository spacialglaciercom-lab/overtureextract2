# Mapbox Configuration
# Get your free token at https://account.mapbox.com
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Backend API Configuration
# Your Railway backend URL
EXPO_PUBLIC_API_BASE_URL=https://your-app.up.railway.app

# Map Style URL
# Carto Dark Matter (free, default)
EXPO_PUBLIC_MAP_STYLE=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# Alternative: Stadia Maps (requires API key)
# EXPO_PUBLIC_MAP_STYLE=https://tiles.stadiamaps.com/styles/dark.json

# Alternative: Mapbox Dark (uses your token)
# EXPO_PUBLIC_MAP_STYLE=mapbox://styles/mapbox/dark-v11
